        self.win = tk.Toplevel(parent)
        self.win.title("Chỉnh sửa ứng dụng")
        self.win.geometry("500x200")
        self.win.grab_set()
        
        self.icon_path = app["icon"]
        self.create_widgets()
        
    def create_widgets(self):
        frame = ttk.Frame(self.win, padding=15)
        frame.pack(fill=tk.BOTH, expand=True)
        
        # Display Name
        ttk.Label(frame, text="Tên hiển thị:").grid(row=0, column=0, sticky=tk.W, pady=5)
        self.ent_name = ttk.Entry(frame, width=35)
        self.ent_name.insert(0, self.app["name"])
        self.ent_name.grid(row=0, column=1, columnspan=2, pady=5, padx=5, sticky=tk.W+tk.E)
        
        # Icon selection
        ttk.Label(frame, text="Biểu tượng (Icon):").grid(row=1, column=0, sticky=tk.W, pady=5)
        self.ent_icon = ttk.Entry(frame, width=35)
        self.ent_icon.insert(0, self.icon_path)
        self.ent_icon.grid(row=1, column=1, pady=5, padx=5)
        ttk.Button(frame, text="Chọn...", command=self.select_icon).grid(row=1, column=2, pady=5)
        
        # Buttons
        btn_frame = ttk.Frame(frame, padding=10)
        btn_frame.grid(row=2, column=0, columnspan=3, pady=15)
        
        ttk.Button(btn_frame, text="Hủy bỏ", command=self.win.destroy).pack(side=tk.LEFT, padx=10)
        ttk.Button(btn_frame, text="Lưu", command=self.save_app).pack(side=tk.LEFT, padx=10)
        
    def select_icon(self):
        file_path = filedialog.askopenfilename(
            title="Chọn hình ảnh làm Icon",
            filetypes=[("Image files", "*.png *.jpg *.jpeg *.svg"), ("All files", "*.*")]
        )
        if file_path:
            self.icon_path = file_path
            self.ent_icon.delete(0, tk.END)
            self.ent_icon.insert(0, file_path)
            
    def save_app(self):
        name = self.ent_name.get().strip()
        icon = self.ent_icon.get().strip()
        
        if not name:
            messagebox.showerror("Lỗi", "Tên ứng dụng không được để trống!")
            return
            
        content = f"""[Desktop Entry]
Name={name}
Exec={MICRO_PROTON_BIN} --prefix "{self.app['prefix']}" "{self.app['exe']}"
Icon={icon}
Terminal=false
Type=Application
Categories=Game;Emulator;Utility;
MimeType=application/x-ms-dos-executable;
Comment=Chạy bằng MicroProton
X-MicroProton-Exe={self.app['exe']}
"""
        try:
            with open(self.app["desktop_file"], "w", encoding="utf-8") as f:
                f.write(content)
            
            # Update desktop database
            subprocess.run(["update-desktop-database", APPLICATIONS_DIR])
            self.callback()
            self.win.destroy()
        except Exception as e:
            messagebox.showerror("Lỗi", f"Không thể lưu ứng dụng: {e}")

if __name__ == "__main__":
    root = tk.Tk()
    app = AppManagerWindow(root)
    root.mainloop()
