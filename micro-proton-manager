    def delete_app(self):
        app = self.get_selected_app()
        if not app:
            return
            
        confirm = messagebox.askyesno(
            "Xác nhận xóa", 
            f"Bạn có chắc muốn gỡ bỏ ứng dụng '{app['name']}' khỏi danh sách ứng dụng Fedora/Linux không?"
        )
        if not confirm:
            return
            
        try:
            if os.path.exists(app["desktop_file"]):
                os.remove(app["desktop_file"])
        except Exception as e:
            messagebox.showerror("Lỗi", f"Không thể xóa tệp desktop: {e}")
            return
            
        delete_prefix = messagebox.askyesno(
            "Xóa bộ nhớ đệm (Prefix)",
            "Bạn có muốn xóa toàn bộ ổ C: ảo (Prefix) của ứng dụng này để giải phóng dung lượng đĩa không?\n(Hành động này sẽ xóa tất cả lưu trữ/save game bên trong ứng dụng)."
        )
        if delete_prefix:
            prefix_dir = app["prefix"]
            if os.path.exists(prefix_dir):
                try:
                    shutil.rmtree(prefix_dir)
                    messagebox.showinfo("Thành công", "Đã xóa ứng dụng và ổ C: ảo thành công.")
                except Exception as e:
                    messagebox.showerror("Lỗi", f"Không thể xóa thư mục ổ C: ảo: {e}")
            else:
                messagebox.showinfo("Thành công", "Đã gỡ ứng dụng. Thư mục ổ C: ảo không tồn tại hoặc đã được xóa trước đó.")
        else:
            messagebox.showinfo("Thành công", "Đã gỡ ứng dụng nhưng giữ lại ổ C: ảo.")
            
        subprocess.run(["update-desktop-database", APPLICATIONS_DIR])
        self.refresh_list()

    def backup_prefix(self):
        app = self.get_selected_app()
        if not app:
            return
            
        prefix_dir = app["prefix"]
        app_name = app["name"]
        
        file_path = filedialog.asksaveasfilename(
            title=f"Sao lưu Prefix cho {app_name}",
            initialfile=f"micro_proton_{app_name.lower().replace(' ', '_')}_backup.zip",
            filetypes=[("Zip Archive", "*.zip")]
        )
        if not file_path:
            return
            
        if file_path.endswith(".zip"):
            base_name = file_path[:-4]
        else:
            base_name = file_path
            
        def run_zip():
            try:
                shutil.make_archive(base_name, 'zip', prefix_dir)
