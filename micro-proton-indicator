#!/usr/bin/env python3
import os
import sys
import subprocess
import glob
import re
import socket
import threading
import time
import gi

gi.require_version('Gtk', '3.0')
gi.require_version('AppIndicator3', '0.1')
from gi.repository import Gtk, AppIndicator3, GObject, GLib

STEAM_PATH = os.path.expanduser("~/.local/share/Steam")
STEAM_COMMON = os.path.join(STEAM_PATH, "steamapps/common")
PREFIXES_DIR = os.path.expanduser("~/.local/share/micro-proton/prefixes")
GLOBAL_PREFIX = os.path.join(PREFIXES_DIR, "global_default")
APPLICATIONS_DIR = os.path.expanduser("~/.local/share/applications")

# Single instance lock for indicator
_indicator_socket = None
def check_indicator_single_instance(port=18246):
    global _indicator_socket
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.bind(('127.0.0.1', port))
        s.listen(1)
        _indicator_socket = s
        return True
    except socket.error:
        return False

def find_proton_versions():
    versions = []
    if os.path.exists(STEAM_COMMON):
        for item in os.listdir(STEAM_COMMON):
            if item.startswith("Proton") and os.path.isdir(os.path.join(STEAM_COMMON, item)):
                proton_script = os.path.join(STEAM_COMMON, item, "proton")
                if os.path.exists(proton_script):
                    versions.append((item, proton_script))
    compat_dir = os.path.join(STEAM_PATH, "compatibilitytools.d")
    if os.path.exists(compat_dir):
        for item in os.listdir(compat_dir):
            item_path = os.path.join(compat_dir, item)
            if os.path.isdir(item_path):
                proton_script = os.path.join(item_path, "proton")
                if os.path.exists(proton_script):
                    versions.append((item, proton_script))
                    
    # Fallback to system wine
    import shutil
    wine_path = shutil.which("wine")
    if wine_path:
        versions.append(("System Wine (Fallback)", wine_path))
        
    seen_paths = set()
    unique_versions = []
    for name, path in versions:
        if path not in seen_paths:
            seen_paths.add(path)
            unique_versions.append((name, path))
            
    def sort_key(v):
        name = v[0]
        if "System Wine" in name:
            return -1.0
        if "Experimental" in name:
            return 999.0
        numbers = re.findall(r"\d+", name)
        if numbers:
            if len(numbers) >= 2:
                return float(f"{numbers[0]}.{numbers[1].zfill(3)}")
            return float(numbers[0])
        return 0.0
    unique_versions.sort(key=sort_key, reverse=True)
    return unique_versions

def get_proton_running_status():
    exe_to_name = {}
    if os.path.exists(APPLICATIONS_DIR):
        for f in os.listdir(APPLICATIONS_DIR):
            if f.startswith("micro-proton-app-") and f.endswith(".desktop"):
                path = os.path.join(APPLICATIONS_DIR, f)
                try:
                    with open(path, "r", encoding="utf-8") as file:
                        content = file.read()
                    name_match = re.search(r"^Name=(.*)$", content, re.MULTILINE)
                    exe_match = re.search(r"^X-MicroProton-Exe=(.*)$", content, re.MULTILINE)
                    if name_match and exe_match:
                        exe_to_name[os.path.abspath(exe_match.group(1).strip())] = name_match.group(1).strip()
                except Exception:
                    pass

    my_uid = os.getuid()
    matched_pids = {}
    parent_map = {}
    is_taskbar_running = False
    
    for pid_dir in glob.glob("/proc/[0-9]*"):
        pid = os.path.basename(pid_dir)
        try:
            stat_info = os.stat(pid_dir)
            if stat_info.st_uid != my_uid:
                continue
                
            stat_path = os.path.join(pid_dir, "stat")
            ppid = "0"
            if os.path.exists(stat_path):
                with open(stat_path, "r") as f:
                    stat_content = f.read()
                r_paren = stat_content.rfind(')')
                if r_paren != -1:
                    parts = stat_content[r_paren+2:].split()
                    if len(parts) >= 2:
                        ppid = parts[1]
            parent_map[pid] = ppid
            
            cmdline_path = os.path.join(pid_dir, "cmdline")
            if os.path.exists(cmdline_path):
                with open(cmdline_path, "rb") as f:
                    cmd_data = f.read()
                cmd_str = cmd_data.decode("utf-8", errors="ignore").replace("\x00", " ")
                
                if "explorer.exe" in cmd_str:
                    environ_path = os.path.join(pid_dir, "environ")
                    if os.path.exists(environ_path):
                        with open(environ_path, "rb") as f:
                            env_data = f.read()
                        env_list = env_data.decode("utf-8", errors="ignore").split("\x00")
                        for item in env_list:
                            if item.startswith("WINEPREFIX="):
                                wp = item.split("=", 1)[1]
                                if os.path.abspath(wp) == os.path.abspath(os.path.join(GLOBAL_PREFIX, "pfx")):
                                    is_taskbar_running = True
                                    break
                
                for exe_path, game_name in exe_to_name.items():
                    game_dir = os.path.dirname(exe_path)
                    if exe_path in cmd_str or game_dir in cmd_str:
                        matched_pids[pid] = game_name
                        break
                    else:
                        exe_basename = os.path.basename(exe_path)
                        if exe_basename in cmd_str and ("proton" in cmd_str or "wine" in cmd_str):
                            matched_pids[pid] = game_name
                            break
        except Exception:
            continue

    added_new = True
    while added_new:
        added_new = False
        for pid, ppid in parent_map.items():
            if pid not in matched_pids and ppid in matched_pids:
                matched_pids[pid] = matched_pids[ppid]
                added_new = True

    if not matched_pids:
        return False, "MicroProton: Đang dừng", [], is_taskbar_running

    pids = list(matched_pids.keys())
    total_cpu = 0.0
    total_mem_kb = 0
    
    try:
        res = subprocess.run(
            ["ps", "-p", ",".join(pids), "-o", "pid,%cpu,rss"],
            capture_output=True, text=True, check=True
        )
        lines = res.stdout.strip().split("\n")[1:]
        for line in lines:
            parts = line.split()
            if len(parts) >= 3:
                total_cpu += float(parts[1])
                total_mem_kb += int(parts[2])
    except Exception:
        pass

    mem_mb = total_mem_kb / 1024.0
    running_games = sorted(list(set(matched_pids.values())))
    games_str = ", ".join(running_games)
    
    status_text = f"Đang chạy: {games_str} (CPU: {total_cpu:.1f}%, RAM: {mem_mb:.1f} MB)"
    return True, status_text, running_games, is_taskbar_running

class MicroProtonIndicator:
    def __init__(self):
        self.indicator = AppIndicator3.Indicator.new(
            "micro-proton-indicator",
            "preferences-desktop-keyboard",
            AppIndicator3.IndicatorCategory.APPLICATION_STATUS
        )
        self.indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
        
        self.menu = Gtk.Menu()
        
        self.menu_status = Gtk.MenuItem(label="MicroProton: Đang dừng")
        self.menu_status.set_sensitive(False)
        self.menu.append(self.menu_status)
        
        self.menu.append(Gtk.SeparatorMenuItem())
        
        menu_manager = Gtk.MenuItem(label="Mở Manager")
        menu_manager.connect("activate", self.open_manager)
        self.menu.append(menu_manager)
        
        self.menu_taskbar = Gtk.MenuItem(label="Mở màn hình Windows")
        self.menu_taskbar.connect("activate", self.toggle_taskbar)
        self.menu.append(self.menu_taskbar)
        
        menu_unikey = Gtk.MenuItem(label="Khởi chạy UniKey (Proton)")
        menu_unikey.connect("activate", self.launch_unikey)
        self.menu.append(menu_unikey)
        
        self.menu.append(Gtk.SeparatorMenuItem())
        
        menu_kill = Gtk.MenuItem(label="Tắt toàn bộ tiến trình (Kill)")
        menu_kill.connect("activate", self.kill_all)
        self.menu.append(menu_kill)
        
        menu_exit = Gtk.MenuItem(label="Thoát")
        menu_exit.connect("activate", self.quit)
        self.menu.append(menu_exit)
        
        self.menu.show_all()
        self.indicator.set_menu(self.menu)
        
        self.is_running = False
        self.is_taskbar_active = False
        
        threading.Thread(target=self.monitor_loop, daemon=True).start()

    def open_manager(self, widget):
        manager_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "micro-proton-manager")
        if os.path.exists(manager_path):
            subprocess.Popen([sys.executable, manager_path])
        else:
            subprocess.Popen(["micro-proton-manager"])

    def toggle_taskbar(self, widget):
        proton_versions = find_proton_versions()
        if not proton_versions:
            return
        proton_name, proton_path = proton_versions[0]
        
        is_system_wine = "wine" in os.path.basename(proton_path).lower()
        env = os.environ.copy()
        env["WINEPREFIX"] = GLOBAL_PREFIX
        if not is_system_wine:
            env["STEAM_COMPAT_CLIENT_INSTALL_PATH"] = STEAM_PATH
            env["STEAM_COMPAT_DATA_PATH"] = GLOBAL_PREFIX
        
        if self.is_taskbar_active:
            my_uid = os.getuid()
            for pid_dir in glob.glob("/proc/[0-9]*"):
                pid = os.path.basename(pid_dir)
                try:
                    stat_info = os.stat(pid_dir)
                    if stat_info.st_uid != my_uid:
                        continue
                    cmdline_path = os.path.join(pid_dir, "cmdline")
                    if os.path.exists(cmdline_path):
                        with open(cmdline_path, "rb") as f:
                            cmd_data = f.read()
                        cmd_str = cmd_data.decode("utf-8", errors="ignore").replace("\x00", " ")
                        if "explorer.exe" in cmd_str:
                            subprocess.run(["kill", "-9", pid])
                except Exception:
                    pass
        else:
            taskbar_env = env.copy()
            if not is_system_wine:
                taskbar_env["PROTON_NO_PATH_TRANSLATION"] = "1"
                subprocess.Popen([proton_path, "run", "explorer.exe", "/desktop=Default,1280x720"], env=taskbar_env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            else:
                subprocess.Popen([proton_path, "explorer.exe", "/desktop=Default,1280x720"], env=taskbar_env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def launch_unikey(self, widget):
        proton_versions = find_proton_versions()
        if not proton_versions:
            return
        proton_name, proton_path = proton_versions[0]
        
        is_system_wine = "wine" in os.path.basename(proton_path).lower()
        env = os.environ.copy()
        env["WINEPREFIX"] = GLOBAL_PREFIX
        if not is_system_wine:
            env["STEAM_COMPAT_CLIENT_INSTALL_PATH"] = STEAM_PATH
            env["STEAM_COMPAT_DATA_PATH"] = GLOBAL_PREFIX
        
        unikey_exe = os.path.join(GLOBAL_PREFIX, "pfx/drive_c/UniKey/UniKeyNT.exe")
        if os.path.exists(unikey_exe):
            if is_system_wine:
                subprocess.Popen([proton_path, unikey_exe], env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            else:
                subprocess.Popen([proton_path, "run", unikey_exe], env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        else:
            import shutil
            if shutil.which("zenity"):
                subprocess.Popen(["zenity", "--info", "--text=Vui lòng mở Manager và bật UniKey trong Cấu hình hệ thống để tự động tải về trước.", "--title=UniKey chưa được tải"])
            else:
                try:
                    import tkinter as tk
                    from tkinter import messagebox
                    root = tk.Tk()
                    root.withdraw()
                    root.attributes("-topmost", True)
                    messagebox.showinfo("UniKey chưa được tải", "Vui lòng mở Manager và bật UniKey trong Cấu hình hệ thống để tự động tải về trước.", parent=root)
                    root.destroy()
                except Exception:
                    print("[UniKey chưa được tải] Vui lòng mở Manager và bật UniKey trong Cấu hình hệ thống để tự động tải về trước.")

    def kill_all(self, widget):
        proton_versions = find_proton_versions()
        if not proton_versions:
            return
        proton_name, proton_path = proton_versions[0]
        
        is_system_wine = "wine" in os.path.basename(proton_path).lower()
        env = os.environ.copy()
        env["WINEPREFIX"] = GLOBAL_PREFIX
        if not is_system_wine:
            env["STEAM_COMPAT_CLIENT_INSTALL_PATH"] = STEAM_PATH
            env["STEAM_COMPAT_DATA_PATH"] = GLOBAL_PREFIX
            
            proton_dir = os.path.dirname(proton_path)
            wineserver_path = os.path.join(proton_dir, "files/bin/wineserver")
            if os.path.exists(wineserver_path):
                subprocess.Popen([wineserver_path, "-k"], env=env)
            else:
                subprocess.Popen([proton_path, "run", "wineserver", "-k"], env=env)
        else:
            import shutil
            wineserver_bin = shutil.which("wineserver") or "wineserver"
            subprocess.Popen([wineserver_bin, "-k"], env=env)

        # Force-kill any remaining stale wine processes for this user to resolve version mismatches
        import glob
        my_uid = os.getuid()
        for pid_dir in glob.glob("/proc/[0-9]*"):
            try:
                stat_info = os.stat(pid_dir)
                if stat_info.st_uid != my_uid:
                    continue
                cmdline_path = os.path.join(pid_dir, "cmdline")
                if os.path.exists(cmdline_path):
                    with open(cmdline_path, "rb") as f:
                        cmd_data = f.read()
                    cmd_str = cmd_data.decode("utf-8", errors="ignore").replace("\x00", " ")
                    if any(x in cmd_str for x in ["wineserver", "explorer.exe", "winedevice.exe", "wineboot.exe"]):
                        pid = int(os.path.basename(pid_dir))
                        try:
                            os.kill(pid, 9)
                        except Exception:
                            pass
            except Exception:
                pass

    def quit(self, widget):
        Gtk.main_quit()
        sys.exit(0)

    def monitor_loop(self):
        while True:
            try:
                is_running, status_text, running_games, is_taskbar_running = get_proton_running_status()
                self.is_running = is_running
                self.is_taskbar_active = is_taskbar_running
                GLib.idle_add(self.update_ui, status_text, is_taskbar_running)
            except Exception:
                pass
            time.sleep(2)

    def update_ui(self, status_text, is_taskbar_running):
        self.menu_status.set_label(status_text)
        if is_taskbar_running:
            self.menu_taskbar.set_label("🖥️ Tắt màn hình Windows")
        else:
            self.menu_taskbar.set_label("🖥️ Mở màn hình Windows")

if __name__ == "__main__":
    if not check_indicator_single_instance():
        sys.exit(0)
    GObject.threads_init()
    indicator = MicroProtonIndicator()
    Gtk.main()
