#!/usr/bin/env python3
import os
import sys
import subprocess
import hashlib
import re
import shutil

# Path definitions
STEAM_PATH = os.path.expanduser("~/.local/share/Steam")
STEAM_COMMON = os.path.join(STEAM_PATH, "steamapps/common")
BASE_PREFIX_DIR = os.path.expanduser("~/.local/share/micro-proton/prefixes")

def find_proton_versions():
    """Finds all installed Proton versions in Steam common directory."""
    if not os.path.exists(STEAM_COMMON):
        return []
    
    versions = []
    for item in os.listdir(STEAM_COMMON):
        if item.startswith("Proton") and os.path.isdir(os.path.join(STEAM_COMMON, item)):
            proton_script = os.path.join(STEAM_COMMON, item, "proton")
            if os.path.exists(proton_script):
                versions.append((item, proton_script))
    
    # Sort: Proton 10.0, Proton 9.0, Proton - Experimental
    def sort_key(v):
        name = v[0]
        if "Experimental" in name:
            return 999.0
        # Extract numbers
        numbers = re.findall(r"\d+\.\d+|\d+", name)
        if numbers:
            return float(numbers[0])
        return 0.0
        
    versions.sort(key=sort_key, reverse=True)
    return versions

def select_file_via_zenity():
    """Uses Zenity to prompt the user to select an .exe file."""
    try:
        res = subprocess.run(
            ["zenity", "--file-selection", "--title=Chọn file Windows (.exe)", "--file-filter=Executable files (*.exe) | *.exe"],
            capture_output=True, text=True, check=True
        )
        return res.stdout.strip()
    except subprocess.CalledProcessError:
        return None

def show_message(text, timeout=3, title="MicroProton"):
    """Shows a quick popup message using Zenity."""
    subprocess.Popen(["zenity", "--info", f"--text={text}", f"--timeout={timeout}", f"--title={title}"])

def get_prefix_dir(exe_path):
    """Generates a clean, unique WINEPREFIX path for the executable."""
    abs_path = os.path.abspath(exe_path)
    # Generate unique hash of the path to avoid conflicts
    path_hash = hashlib.md5(abs_path.encode('utf-8')).hexdigest()[:8]
    # Clean up name for folder
    base_name = os.path.basename(abs_path)
    clean_name = re.sub(r'[^a-zA-Z0-9_-]', '_', base_name)
    return os.path.join(BASE_PREFIX_DIR, f"{clean_name}_{path_hash}")

def run_command(proton_path, prefix_dir, exe_path, action="run"):
    """Runs Proton with the specified action and environment."""
    os.makedirs(prefix_dir, exist_ok=True)
    
    # Setup environment variables required by Proton
    env = os.environ.copy()
    env["STEAM_COMPAT_CLIENT_INSTALL_PATH"] = STEAM_PATH
    env["STEAM_COMPAT_DATA_PATH"] = prefix_dir
    
    # Force XIM variables for Vietnamese typing (Fcitx5 / IBus)
    system_xim = os.environ.get("XMODIFIERS", "@im=fcitx")
    env["XMODIFIERS"] = system_xim
    env["GTK_IM_MODULE"] = "xim"
    env["QT_IM_MODULE"] = "xim"
    if "ibus" in system_xim:
        env["SDL_IM_MODULE"] = "ibus"
    else:
        env["SDL_IM_MODULE"] = "fcitx"
    
    # Check if this is the first run for this prefix
    p_wine = os.path.join(prefix_dir, "pfx")
    is_first_run = not os.path.exists(p_wine)
    
    if is_first_run:
        show_message("Đang tạo môi trường chạy (Prefix) lần đầu cho ứng dụng này.\nVui lòng đợi vài giây...", timeout=4)
        
    # Apply input method registry settings if not already applied
    reg_file_path = os.path.join(prefix_dir, "input_style.reg")
    if not os.path.exists(reg_file_path) and action == "run":
        # Write reg file to allow Fcitx/IBus candidate windows
        try:
            with open(reg_file_path, "w") as f:
                f.write("Windows Registry Editor Version 5.00\n\n")
                f.write("[HKEY_CURRENT_USER\\Software\\Wine\\X11 Driver]\n")
                f.write('"InputStyle"="overthespot"\n')
            
            # Silent import by running regedit (this also initializes the prefix)
            subprocess.run([proton_path, "run", "regedit", reg_file_path], env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception as e:
            print(f"Lỗi thiết lập bộ gõ: {e}")
            
    cmd = [proton_path, action]
    if action == "run":
        cmd.append(exe_path)
        
    # Execute the process
    try:
        subprocess.run(cmd, env=env)
    except Exception as e:
        subprocess.run(["zenity", "--error", f"--text=Lỗi khi chạy ứng dụng:\n{str(e)}", "--title=MicroProton Error"])

def main():
    # Find Proton
    proton_list = find_proton_versions()
    if not proton_list:
        subprocess.run(["zenity", "--error", "--text=Không tìm thấy Proton của Steam trên hệ thống.\nVui lòng cài đặt Steam và tải ít nhất một phiên bản Proton (ví dụ Proton 10.0).", "--title=Lỗi hệ thống"])
        sys.exit(1)
        
    proton_name, proton_path = proton_list[0]
    
    # Parse options
    args = sys.argv[1:]
    
    # Parse custom prefix path if passed
    custom_prefix = None
    if "--prefix" in args:
        try:
            idx = args.index("--prefix")
            if idx + 1 < len(args):
                custom_prefix = args[idx + 1]
                args.pop(idx + 1)
                args.pop(idx)
        except ValueError:
            pass

    action = "run"
    exe_path = None
    
    if not args:
        # No arguments, open GUI file selector
        exe_path = select_file_via_zenity()
        if not exe_path:
            sys.exit(0)
    else:
        # Check flags
        if args[0] in ["--winecfg", "-c"]:
            action = "winecfg"
            if len(args) > 1:
                exe_path = args[1]
        elif args[0] in ["--regedit", "-r"]:
            action = "regedit"
            if len(args) > 1:
                exe_path = args[1]
        elif args[0] in ["--kill", "-k"]:
            action = "kill"
            if len(args) > 1:
                exe_path = args[1]
        else:
            exe_path = args[0]
            
    if not exe_path or not os.path.exists(exe_path):
        if action != "run" and not exe_path:
            # Run action on default global prefix if no file is specified
            prefix_dir = custom_prefix or os.path.join(BASE_PREFIX_DIR, "global_default")
            run_command(proton_path, prefix_dir, None, action)
            sys.exit(0)
        subprocess.run(["zenity", "--error", f"--text=Đường dẫn tệp tin không hợp lệ hoặc không tồn tại:\n{exe_path}", "--title=Lỗi đường dẫn"])
        sys.exit(1)
        
    prefix_dir = custom_prefix or get_prefix_dir(exe_path)
    
    if action == "kill":
        # Kill all processes in this prefix using wineserver -k (via Proton)
        show_message("Đang tắt mọi tiến trình trong môi trường chạy này...", timeout=2)
        env = os.environ.copy()
        env["STEAM_COMPAT_CLIENT_INSTALL_PATH"] = STEAM_PATH
        env["STEAM_COMPAT_DATA_PATH"] = prefix_dir
        # Locate wineserver inside Proton
        proton_dir = os.path.dirname(proton_path)
        wineserver_path = os.path.join(proton_dir, "files/bin/wineserver")
        if os.path.exists(wineserver_path):
            subprocess.run([wineserver_path, "-k"], env=env)
        else:
            # Fallback
            subprocess.run([proton_path, "run", "wineserver", "-k"], env=env)
    else:
        run_command(proton_path, prefix_dir, exe_path, action)

if __name__ == "__main__":
    main()
